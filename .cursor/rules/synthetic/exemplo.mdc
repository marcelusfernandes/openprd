    valor_base: 7.5
    valor_atual: 7.5
    escala: [0, 10]
    justificativa: "Criativa, aberta a experiências estéticas, curiosa sobre tendências"
  
  conscienciosidade: 
    valor_base: 7.0
    valor_atual: 7.0
    escala: [0, 10]
    justificativa: "Organizada com sua carreira, disciplinada com conteúdo, mas não rígida"
  
  extroversao: 
    valor_base: 7.5
    valor_atual: 7.5
    escala: [0, 10]
    justificativa: "Comunicativa e sociável, mas valoriza momentos de introspecção"
  
