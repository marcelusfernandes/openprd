# ============================================================
# Product Discovery Harness — Environment Variables
# ============================================================
# Copie este arquivo para .env e preencha com suas credenciais.
# NUNCA commite o .env — ele já está no .gitignore.
#
# Não precisa preencher tudo! Configure apenas as ferramentas
# que você usa. Use /setup para configuração guiada.
# ============================================================

# --- Colaboração & Documentação ---

# Atlassian (Jira + Confluence)
CONFLUENCE_URL=                    # https://suaempresa.atlassian.net
CONFLUENCE_USERNAME=               # seu email
CONFLUENCE_API_TOKEN=              # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=                          # https://suaempresa.atlassian.net
JIRA_USERNAME=                     # seu email
JIRA_API_TOKEN=                    # mesmo token do Confluence

# Slack
SLACK_BOT_TOKEN=                   # xoxb-... (criar app em https://api.slack.com/apps)
SLACK_TEAM_ID=                     # T01ABCDEF (na URL do Slack web)

# Notion
NOTION_TOKEN=                      # ntn_... (https://www.notion.so/my-integrations)

# Google Workspace (Docs/Drive)
GOOGLE_CLIENT_ID=                  # OAuth 2.0 Client ID (Google Cloud Console)
GOOGLE_CLIENT_SECRET=              # OAuth 2.0 Client Secret

# --- Analytics & Dados ---

# Amplitude
AMPLITUDE_API_KEY=                 # Settings → Projects → API Key
AMPLITUDE_SECRET_KEY=              # Settings → Projects → Secret Key

# PostHog
POSTHOG_API_KEY=                   # Settings → Personal API Keys
POSTHOG_PROJECT_ID=                # na URL do projeto

# BigQuery
BIGQUERY_PROJECT_ID=               # ID do projeto no Google Cloud
BIGQUERY_LOCATION=US               # US ou EU

# Snowflake
SNOWFLAKE_ACCOUNT=                 # xy12345.us-east-1
SNOWFLAKE_WAREHOUSE=               # COMPUTE_WH
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=                    # ANALYST
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

# Databricks
DATABRICKS_HOST=                   # https://adb-123.azuredatabricks.net
DATABRICKS_TOKEN=                  # User Settings → Developer → Access tokens

# Metabase
METABASE_URL=                      # https://metabase.suaempresa.com
METABASE_API_KEY=                  # Admin → Settings → API Keys

# Tableau
TABLEAU_SERVER=                    # https://10az.online.tableau.com
TABLEAU_SITE_NAME=                 # nome do site na URL
TABLEAU_PAT_NAME=                  # nome do Personal Access Token
TABLEAU_PAT_VALUE=                 # valor do token

# Redash
REDASH_URL=                        # https://redash.suaempresa.com
REDASH_API_KEY=                    # Perfil → API Key

# --- Ferramentas de Produto ---

# LaunchDarkly
LAUNCHDARKLY_API_KEY=              # Account Settings → Authorization → Create token

# Hotjar (API direto)
HOTJAR_CLIENT_ID=                  # Integrations → API → OAuth app
HOTJAR_CLIENT_SECRET=

# Hotjar (via Zapier — alternativa)
ZAPIER_MCP_SERVER_ID=              # mcp.zapier.com → Server URL
ZAPIER_API_KEY=

# Zendesk
ZENDESK_SUBDOMAIN=                 # "suaempresa" de suaempresa.zendesk.com
ZENDESK_EMAIL=                     # email de login
ZENDESK_API_TOKEN=                 # Admin → Channels → API → Add Token

# Intercom
INTERCOM_TOKEN=                    # Developer Hub → Authentication → Access Token

# Salesforce
SALESFORCE_ORG_ALIAS=              # alias definido no sf org login

# Productboard
PRODUCTBOARD_API_TOKEN=            # Settings → Integrations → API

# Dovetail
DOVETAIL_API_TOKEN=                # Settings → API → Personal Token

# Segment
SEGMENT_API_TOKEN=                 # Settings → Access Management → Tokens

# --- Plataformas de Dados ---

# Palantir Foundry
FOUNDRY_API_URL=                   # https://suaempresa.palantirfoundry.com
FOUNDRY_TOKEN=                     # Control Panel → Tokens

# Palantir Gotham
GOTHAM_HOSTNAME=                   # https://gotham.suaempresa.com
GOTHAM_CLIENT_ID=                  # OAuth2 Client ID (pedir ao admin)
GOTHAM_CLIENT_SECRET=              # OAuth2 Client Secret

# --- Email (harness notifications) ---
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=                         # email do remetente
SMTP_PASS=                         # senha do email
